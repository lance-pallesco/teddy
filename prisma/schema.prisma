// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  // output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  SHELTER_STAFF
  PET_OWNER
  ADOPTER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum PetSpecies {
  DOG
  CAT
  RABBIT
  BIRD
  OTHER
}

enum PetSize {
  SMALL
  MEDIUM
  LARGE
  EXTRA_LARGE
}

enum PetStatus {
  AVAILABLE
  PENDING
  ADOPTED
  RESERVED
  MEDICAL_HOLD
  ARCHIVED
}

enum PetGender {
  MALE
  FEMALE
}

model User {
  id        String   @id @default(uuid())
  firstName String
  lastName  String
  phone     String   @unique
  address   String
  gender    Gender
  avatar    String
  role      Role
  isActive  Boolean  @default(true)
  email     String   @unique
  password  String
  failedLoginAttempts Int @default(0)
  lockedUntil DateTime?
  shelterId String?  
  shelter   Shelter? @relation(fields: [shelterId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pets      Pet[]   @relation("PostedPets")
  adoptedPets Pet[] @relation("AdoptedPets")
  @@index([role])
  @@index([shelterId])
  @@index([isActive])
}

model Shelter {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String
  logo        String?

  // Contact & Location
  address     String
  barangay    String?
  city        String
  province    String
  postalCode  String?
  phone       String   @unique
  email       String   @unique

  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  users       User[]   
  pets        Pet[]
  @@index([city])
  @@index([province])
  @@index([isActive])
}

model Pet {
  id            String   @id @default(uuid())
  name          String
  description   String
  species       PetSpecies
  breed         String?
  gender        PetGender?
  size          PetSize

  birthDate     DateTime?
  isAgeEstimated Boolean  @default(false)
  color         String?
  weightKg      Float?
  tags          String[] // e.g.  ["Playful", "Gentle", "Calm", "Energetic", "Friendly", "Shy", "Aggressive", "Independent", "Affectionate", "Social"]
  petImages     PetImage[]

  isVaccinated Boolean  @default(false)
  isNeutered   Boolean  @default(false)
  isHouseTrained Boolean  @default(false)
  goodWithKids Boolean  @default(false)
  goodWithDogs Boolean  @default(false)
  goodWithCats Boolean  @default(false)
  
  specialNeeds      Boolean  @default(false)
  specialNeedsNote  String?

  shelterId     String?
  shelter       Shelter? @relation(fields: [shelterId], references: [id])
  postedById    String?
  postedBy      User?   @relation("PostedPets", fields: [postedById], references: [id])

  adoptedById    String?
  adoptedBy      User?   @relation("AdoptedPets", fields: [adoptedById], references: [id])
  adoptedAt   DateTime?

  status      PetStatus @default(AVAILABLE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([species])
  @@index([size])
  @@index([gender])
  @@index([status])
  @@index([shelterId])
}

model PetImage {
  id        String   @id @default(uuid())
  petId     String
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  url       String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([petId])
}